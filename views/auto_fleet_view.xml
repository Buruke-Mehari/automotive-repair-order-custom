<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="fleet_vehicle_view_form_inherit_repair" model="ir.ui.view">
    <field name='name'>fleet.vehicle.form.inherit.repair</field>
    <field name ='model'>fleet.vehicle</field>
    <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
    <field name="arch" type="xml">
        <div name="button_box" position="inside">
            <button name="action_view_repair_orders"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-history">
                <field name="repair_order_count" widget="statinfo" string="Repairs"/>
            </button>
        </div>
    </field>
</record>
</odoo>