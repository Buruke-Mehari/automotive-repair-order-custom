<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <record id="view_partner_form_inherit_repair" model="ir.ui.view">
    <field name ='name'>res.partner.form.inherit.repair</field>
    <field name ='model'>res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
        <div name="button_box" position="inside">
            <button name="action_view_repair_orders"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-wrench">
                <field name="repair_order_count" widget="statinfo" string="Repair Orders"/>
            </button>
        </div>
    </field>
</record>
</odoo>