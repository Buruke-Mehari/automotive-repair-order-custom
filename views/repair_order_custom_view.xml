<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. TREE (LIST) VIEW -->
    <record id="view_repair_order_tree" model="ir.ui.view">
        <field name="name">automotive.order.tree</field>
        <field name="model">automotive.order</field>
        <field name="arch" type="xml">
            <tree string="Repair Orders">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_license_plate"/>
                <field name="date_in"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-info="state == 'received'" decoration-warning="state == 'progress'" decoration-success="state in ('ready', 'delivered')"/>
           
                <field name="create_uid" widget="many2one_avatar_user" optional="show"/>
                <field name="create_date" optional="hide"/> <field name="state" widget="badge" decoration-info="state == 'received'" decoration-warning="state == 'progress'" decoration-success="state in ('ready', 'delivered')"/>
            </tree>
        </field>
    </record>

    <!-- 2. FORM VIEW -->
    <record id="view_repair_order_form" model="ir.ui.view">
        <field name="name">automotive.order.form</field>
        <field name="model">automotive.order</field>
        <field name="arch" type="xml">
            <form string="Automotive Repair Order">
                <header>
                    <button name="action_receive_vehicle" type="object" string="Receive Vehicle" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start_repair" type="object" string="Start Repair" class="oe_highlight" invisible="state != 'received'"/>
                    <button name="action_make_ready" type="object" string="Mark Ready" class="oe_highlight" invisible="state != 'progress'"/>
                    <button name="action_deliver_vehicle" type="object" string="Deliver" class="oe_highlight" invisible="state != 'ready'"/>
                    
                    <!-- NEW EMAIL BUTTON: Triggers the python composer method -->
                    <button name="action_send_repair_order_email" type="object" string="Send Repair Order" class="oe_highlight" icon="fa-envelope" invisible="state == 'cancelled'"/>
                    <button name="action_create_final_invoice" string="Create Invoice" type="object" class="btn-secondary" invisible="state not in ['ready', 'delivered']"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('delivered', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,received,progress,ready,delivered"/>
                </header>
                <sheet>
                    <!-- Alert Dashboard Integration Layer -->
                   
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Core Identity">
                            <field name="partner_id" readonly="state in ['delivered', 'cancelled']"/>
                            <field name="sale_order_id" readonly="state in ['delivered', 'cancelled']"/>
                            <field name="user_id" readonly="state in ['delivered', 'cancelled']"/>
                        </group>
                        <group string="Asset Ingest parameters">
                            <field name="vehicle_id" readonly="state in ['delivered', 'cancelled']"/>
                            <field name="vehicle_license_plate" readonly="state in ['delivered', 'cancelled']"/>
                            <field name="vehicle_mileage" readonly="state in ['delivered', 'cancelled']"/>
                            <field name="date_in" readonly="1"/>
                            <field name="date_delivered" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statement of Work Operations">
                            <field name="requested_work" placeholder="Specify operations parameters..." readonly="state in ['delivered', 'cancelled']"/>
                        </page>
                        <page string="Signatures Validation">
                            <group>
                                <group string="Customer Handoff">
                                    <field name="customer_signature" widget="signature" readonly="state == 'delivered'"/>
                                    <field name="customer_signed_by" readonly="state == 'delivered'"/>
                                    <field name="customer_signed_on" readonly="1"/>
                                </group>
                                <group string="Workshop Sign-Off">
                                    <field name="tech_signature" widget="signature" readonly="state == 'delivered'"/>
                                    <field name="tech_signed_by" readonly="state == 'delivered'"/>
                                    <field name="tech_signed_on" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Internal Metadata Logging">
                            <field name="internal_notes" placeholder="Internal structural commentary..."/>
                        </page>
                    </notebook>
                </sheet>
                
                <!-- CHATTER SYSTEM: Required for mail.compose.message wizard tracking -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

   



    <!-- 3. ACTION DEFINITION -->
    <record id="action_automotive_repair_order" model="ir.actions.act_window">
        <field name="name">Automotive Repair Orders</field>
        <field name="res_model">automotive.order</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first automotive repair order!
            </p>
        </field>
    </record>

    <!-- 4. MENU ITEMS -->
    <menuitem id="menu_automotive_repair_root" 
              name="Automotive Repair" 
              web_icon="base,static/description/icon.png"
              groups="repair_order_custom.group_automotive_manager"
              sequence="10"/>

    <menuitem id="menu_automotive_repair_orders" 
              name="Repair Orders" 
              parent="menu_automotive_repair_root" 
              action="action_automotive_repair_order"
              groups="repair_order_custom.group_automotive_manager"
              sequence="10"/>
</odoo>