<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_automotive_management" model="ir.module.category">
        <field name="name">Repair Management</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_automotive_user" model="res.groups">
        <field name="name">User / Technician</field>
        <field name="category_id" ref="module_category_automotive_management"/>
    </record>

    <record id="group_automotive_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_automotive_management"/>
        <field name="implied_ids" eval="[(4, ref('group_automotive_user'))]"/>
    </record>
</odoo>